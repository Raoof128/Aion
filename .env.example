EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for voice-to-text on iOS and Android (Whisper transcription)
EXPO_PUBLIC_OPENAI_KEY=your-openai-key

# Dev bypass: set this to skip rate limiting during testing
# REMOVE THIS or leave empty for production/App Store builds
EXPO_PUBLIC_DEV_BYPASS=
