{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Aion",
  "version": "0.1.0",
  "identifier": "com.aion.app",
  "build": {
    "devUrl": "http://localhost:8083",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aion — AI Bible Companion",
        "width": 420,
        "height": 780,
        "resizable": true,
        "minWidth": 380,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
